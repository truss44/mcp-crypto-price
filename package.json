{
  "name": "mcp-crypto-price",
  "version": "3.5.12",
  "description": "A Model Context Protocol (MCP) server that provides real-time cryptocurrency data and analysis through CoinCap's API. Features include price tracking, market analysis, and historical trends.",
  "license": "MIT",
  "author": {
    "name": "Tracey Russell"
  },
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "mcp-crypto-price": "./dist/index.js"
  },
  "files": [
    "dist",
    "dist/**/*"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "start": "node dist/http.js",
    "start:http": "node dist/http.js",
    "start:stdio": "node dist/index.js",
    "prepare": "pnpm build",
    "watch": "tsc --watch",
    "inspector": "pnpm dlx @modelcontextprotocol/inspector dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "types:check": "tsc --noEmit",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage",
    "prepublishOnly": "pnpm build",
    "release": "semantic-release"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.4",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "claude",
    "crypto",
    "cryptocurrency",
    "coincap",
    "price",
    "market-analysis",
    "trading",
    "finance"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truss44/mcp-crypto-price.git"
  },
  "bugs": {
    "url": "https://github.com/truss44/mcp-crypto-price/issues"
  },
  "homepage": "https://github.com/truss44/mcp-crypto-price"
}
